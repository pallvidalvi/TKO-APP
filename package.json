{
  "name": "vehicle-categories",
  "version": "1.0.0",
  "description": "A React Native app showcasing vehicle categories using Expo",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "build:android-apk": "eas build --platform android --local",
    "build:android-aab": "eas build --platform android --local",
    "preview": "eas build --platform android --profile preview --local"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.0",
    "expo": "~54.0.0",
    "expo-file-system": "^55.0.12",
    "expo-sharing": "^55.0.14",
    "expo-status-bar": "~3.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~19.1.0",
    "@types/react-native": "~0.73.0"
  },
  "private": true
}
